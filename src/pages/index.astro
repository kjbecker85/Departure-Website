---
import Layout from '../layouts/Layout.astro';
import PhoneMockup from '../components/PhoneMockup.astro';
---

<Layout title="Departure: Fitness Quest — Train Like a Warrior">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 bg-gradient-to-b from-primary/10 via-bg to-bg pointer-events-none"></div>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-20 pb-16 lg:pt-32 lg:pb-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy -->
        <div class="text-center lg:text-left">
          <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 rounded-full px-4 py-1.5 mb-6">
            <span class="w-2 h-2 bg-green rounded-full animate-pulse"></span>
            <span class="text-primary-light text-sm font-medium">Available on iOS & Android</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
            Train like a
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">warrior.</span>
            <br />
            Transform like a
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold to-red">legend.</span>
          </h1>

          <p class="text-text-muted text-lg sm:text-xl max-w-lg mx-auto lg:mx-0 mb-8">
            The fitness RPG that turns every workout into an epic quest. Track real exercises, earn XP, battle monsters with your team, and watch your AI-powered transformation unfold.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start" id="download">
            <a href="#" class="inline-flex items-center justify-center gap-3 bg-white text-black px-6 py-3 rounded-xl font-semibold hover:bg-gray-100 transition-colors">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              App Store
            </a>
            <a href="#" class="inline-flex items-center justify-center gap-3 bg-white text-black px-6 py-3 rounded-xl font-semibold hover:bg-gray-100 transition-colors">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.807 1.626a1 1 0 0 1 0 1.732l-2.807 1.626L15.206 12l2.492-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
              Google Play
            </a>
          </div>

          <p class="text-text-muted text-sm mt-4">Free to play. No paywall.</p>
        </div>

        <!-- Right: Phone mockup -->
        <div class="flex justify-center lg:justify-end">
          <PhoneMockup src="/screenshots/home-screen.png" alt="Departure home screen showing Future Self, XP progression, and warrior stats" class="max-w-[280px] sm:max-w-[320px]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Feature highlights -->
  <section class="py-20 lg:py-28 bg-surface/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Not another workout tracker.</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">Departure combines real fitness tracking with RPG progression, team battles, and AI-powered body transformation to keep you coming back.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1: Real Tracking -->
        <div class="bg-surface border border-surface-light/50 rounded-2xl p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Real Workout Tracking</h3>
          <p class="text-text-muted text-sm">10 exercise categories, 88+ exercises, sets, reps, weight. Personal records auto-detected. This isn't "do 50 pushups" — it's your actual training log.</p>
        </div>

        <!-- Feature 2: RPG Progression -->
        <div class="bg-surface border border-surface-light/50 rounded-2xl p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Warrior Progression</h3>
          <p class="text-text-muted text-sm">24 rank tiers from Recruit to Legend. Earn XP, collect equipment, boost your STR/VIT/RES/END stats. Your character grows as you do.</p>
        </div>

        <!-- Feature 3: Team Battles -->
        <div class="bg-surface border border-surface-light/50 rounded-2xl p-6 hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 bg-red/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Team Monster Battles</h3>
          <p class="text-text-muted text-sm">Form a team, fight 24 monsters across 6 themed worlds. Your workouts fuel your team's power. From Goblin Scouts to the Celestial Arbiter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Transformation Section -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 flex justify-center">
          <PhoneMockup src="/screenshots/transformation.png" alt="AI-powered body transformation showing current and projected physique" class="max-w-[280px] sm:max-w-[320px]" />
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 mb-4">
            <span class="text-accent text-sm font-medium">AI-Powered</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">See your future self.</h2>
          <p class="text-text-muted text-lg mb-6">
            Upload a selfie and set your goals. Our AI generates a realistic image of what you could look like — your best possible transformation. It's not a filter. It's a target.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-text-muted text-sm">Personalized to your body, goals, and timeline</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-text-muted text-sm">Factors in your nutrition, workout frequency, and commitment</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-text-muted text-sm">Track progress photos and compare over time</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Battle Section -->
  <section class="py-20 lg:py-28 bg-surface/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-red/10 border border-red/20 rounded-full px-4 py-1.5 mb-4">
            <span class="text-red text-sm font-medium">Team Arena</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">Battle monsters together.</h2>
          <p class="text-text-muted text-lg mb-6">
            Join a team and fight through 24 increasingly powerful monsters across six themed worlds. Every workout contributes to your team's combat power. The harder you train, the harder you hit.
          </p>
          <div class="grid grid-cols-3 gap-4">
            <div class="bg-surface border border-surface-light/50 rounded-xl p-3 text-center">
              <p class="text-2xl font-bold text-primary-light">24</p>
              <p class="text-text-muted text-xs">Monsters</p>
            </div>
            <div class="bg-surface border border-surface-light/50 rounded-xl p-3 text-center">
              <p class="text-2xl font-bold text-gold">6</p>
              <p class="text-text-muted text-xs">Worlds</p>
            </div>
            <div class="bg-surface border border-surface-light/50 rounded-xl p-3 text-center">
              <p class="text-2xl font-bold text-red">2</p>
              <p class="text-text-muted text-xs">Tiers</p>
            </div>
          </div>
        </div>
        <div class="flex justify-center gap-4">
          <PhoneMockup src="/screenshots/team-journey.png" alt="Team journey map with monster battles" class="max-w-[240px]" />
          <PhoneMockup src="/screenshots/battle-results.png" alt="Battle results screen showing defeat against Kraken" class="max-w-[240px] hidden sm:block mt-12" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Ready to begin your quest?</h2>
      <p class="text-text-muted text-lg mb-8">
        Free to download. No paywall. No ads. Just you, your workouts, and the warrior within.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#" class="inline-flex items-center justify-center gap-3 bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-xl font-semibold transition-colors text-lg">
          Download Free
        </a>
      </div>
    </div>
  </section>
</Layout>
